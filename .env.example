NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Use the Supavisor session pooler on port 5432 for a persistent IPv4 VPS.
DATABASE_URL=postgresql://postgres.your-project:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Server only. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_your_server_key

JBD_AUTH_SECRET=replace-with-at-least-32-random-characters
